{
  "name": "cortexlab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron.cjs",
  "author": "Gustavo Oliveira",
  "description": "CortexLab - Plataforma de estudos",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "vite build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "build": {
    "appId": "com.cortexlab.app",
    "productName": "CortexLab",
    "files": [
      "dist/**/*",
      "electron.cjs",
      "preload.js",
      "public/**/*"
    ],
    "extraResources": [],
    "asar": true,
    "win": {
      "target": "nsis",
      "icon": "public/cortexlab.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    }
  },
  "dependencies": {
    "@solar-icons/react": "^1.1.0",
    "@vercel/analytics": "^2.0.1",
    "dexie": "^4.0.11",
    "firebase": "^12.12.1",
    "keytar": "^7.9.0",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hot-toast": "^2.5.2",
    "react-virtualized-auto-sizer": "^2.0.3",
    "react-window": "^2.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9.1.2",
    "electron": "^41.3.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "fake-indexeddb": "^6.2.5",
    "globals": "^16.0.0",
    "jsdom": "^29.1.0",
    "vite": "^6.3.5",
    "vitest": "^4.1.5",
    "wait-on": "^8.0.3"
  }
}
